<Style xmlns="https://github.com/avaloniaui"
	   xmlns:ctls="using:CBSApp.Controls"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Style.Resources>

		<ControlTheme TargetType="ctls:SettingsCard" x:Key="{x:Type ctls:SettingsCard}">
			<Setter Property="Template">
				<ControlTemplate TargetType="ctls:SettingsCard">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Border Grid.Column="0"
								CornerRadius="5" ClipToBounds="True"
								Background="{DynamicResource CBSCardBG}"
								Margin="10">

							<Grid ColumnDefinitions="*,*">

								<ctls:BackdropBlurControl Grid.ColumnSpan="4"/>

								<StackPanel Grid.Column="0" VerticalAlignment="Center">

									<TextBlock Grid.Row="0" Padding="10" VerticalAlignment="Center"
											   Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
												 TextWrapping="WrapWithOverflow"></TextBlock>
									<TextBlock Grid.Row="1"
											   Padding="10,0,0,10"
											   Foreground="{DynamicResource SystemBaseMediumColor}"
											   VerticalAlignment="Center"
											   Text="{Binding Description, RelativeSource={RelativeSource TemplatedParent}}"
											   IsVisible="{Binding Description, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static ObjectConverters.IsNotNull}}"
											   TextWrapping="WrapWithOverflow"></TextBlock>

								</StackPanel>


								<ContentPresenter Content="{TemplateBinding Content}"
												  Grid.Column="1" HorizontalAlignment="Right"
												  VerticalAlignment="Center"></ContentPresenter>
							</Grid>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter>
		</ControlTheme>

		<ControlTheme x:Key="FluentCalendarButton" TargetType="Button">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
			<Setter Property="Background" Value="{DynamicResource CalendarViewNavigationButtonBackground}" />
			<Setter Property="Template">
				<ControlTemplate>
					<!-- HCA was changed here to ensure nav arrows display correctly -->
					<ContentPresenter Name="PART_ContentPresenter" Background="{TemplateBinding Background}"
									  BorderBrush="{DynamicResource CalendarViewNavigationButtonBorderBrush}"
									  BorderThickness="{TemplateBinding BorderThickness}"
									  Content="{TemplateBinding Content}"
									  Margin="0"
									  HorizontalContentAlignment="Stretch"
									  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
				</ControlTemplate>
			</Setter>

			<Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="BorderBrush" Value="{DynamicResource CalendarViewNavigationButtonBorderBrushPointerOver}" />
				<Setter Property="Foreground" Value="{DynamicResource CalendarViewNavigationButtonForegroundPointerOver}" />
			</Style>
			<Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Foreground" Value="{DynamicResource CalendarViewNavigationButtonForegroundPressed}" />
			</Style>
			<Style Selector="^:disabled /template/ ContentPresenter">
				<Setter Property="Foreground" Value="{DynamicResource CalendarViewWeekDayForegroundDisabled}" />
			</Style>
		</ControlTheme>
	</Style.Resources>
</Style>
