<Styles xmlns="https://github.com/avaloniaui"
		xmlns:ctls="using:CBSApp.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20" Background="{DynamicResource CBSCardBG}">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

  <!-- Add Styles Here -->

	<Styles.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key='Light'>
					<SolidColorBrush x:Key='CBSCardBG'>#dddddd</SolidColorBrush>
					<SolidColorBrush x:Key='CBSCoreBG'>#fff</SolidColorBrush>

					<SolidColorBrush x:Key='CBSProgressBG'>#eee</SolidColorBrush>
				</ResourceDictionary>
				<ResourceDictionary x:Key='Dark'>
					<SolidColorBrush x:Key='CBSCardBG'>#9E222222</SolidColorBrush>
					<SolidColorBrush x:Key='CBSCoreBG'>#111</SolidColorBrush>
					
					<SolidColorBrush x:Key='CBSProgressBG'>#000</SolidColorBrush>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</Styles.Resources>
</Styles>
