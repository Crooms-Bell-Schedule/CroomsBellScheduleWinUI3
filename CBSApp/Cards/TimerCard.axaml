<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:ctls="using:CBSApp.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CBSApp.Cards.TimerCard">
	<Grid Margin="10">
		<Border Background="{DynamicResource CBSCardBG}"
									  CornerRadius="15"
									  VerticalAlignment="Stretch"
				ClipToBounds="True"
				HorizontalAlignment="Stretch">
			<Grid Margin="10">
				<Grid.RowDefinitions>
					<RowDefinition Height="auto"/>
					<RowDefinition Height="auto"/>
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<ctls:BackdropBlurControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
										  
										  Grid.RowSpan="3"/>


				<ctls:TimerControl
					Grid.Row="0"
					Grid.Column="0"
					x:Name="Timer"></ctls:TimerControl>

				<ScrollViewer VerticalScrollBarVisibility="Visible" Grid.Row="1" Grid.Column="0">
					<TextBlock x:Name="ScheduleInfo"
					   Margin="5"
							   TextWrapping="WrapWithOverflow">Preparing your schedule...</TextBlock>
				</ScrollViewer>
			</Grid>

		</Border>
	</Grid>
</UserControl>
