<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="200"
        x:Class="CBSApp.Windows.UIMessage"
        Title="Crooms Bell Schedule - Message"
		Icon="/Assets/croomsBellSchedule.ico"
		WindowStartupLocation="CenterScreen"
		Width="500"
		Height="200">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="auto"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="auto"/>
		</Grid.ColumnDefinitions>

		<ScrollViewer Grid.Row="0" Grid.ColumnSpan="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel>
				<TextBlock x:Name="TextTitle"
						   Padding="5"
						   FontSize="26">Title</TextBlock>

				<TextBlock x:Name="TextContent"
						   Padding="5"
						   FontSize="16"
						   TextWrapping="Wrap">Message Message Message Message Message Message Message Message</TextBlock>
			</StackPanel>
		</ScrollViewer>

		<Button Click="Button_Click"
				Grid.Row="3"
				Grid.Column="1"
				Content="OK"
				Margin="10"
				Classes="accent"
				Padding="25,10,25,10"/>
	</Grid>
</Window>
