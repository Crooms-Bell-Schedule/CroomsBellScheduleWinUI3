<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CBSApp.App"
             RequestedThemeVariant="Default"
			 xmlns:sty="using:FluentAvalonia.Styling"
>
	<!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

	<Application.Styles>
		<FluentTheme/>
		
		<StyleInclude Source="avares://CBSApp/Styles/FluentOverride.axaml" />
		<StyleInclude Source="avares://CBSApp/Styles/Controls.axaml" />
		<StyleInclude Source="avares://CBSApp/Styles/Colors.axaml" />

		<!--Todo: load dynamically-->
		<StyleInclude Source="avares://CBSApp/Styles/Themes/Lake.axaml" />
	</Application.Styles>

	<TrayIcon.Icons>
		<TrayIcons>
			<TrayIcon
					Icon="/Assets/croomsBellSchedule.ico"
					  ToolTipText="Crooms Field End App">
				<TrayIcon.Menu>
					<NativeMenu>
						<NativeMenuItem Header="Dashboard / settings" Click="Settings_Click"/>
						<NativeMenuItem Header="Quit" Click="Quit_Click"/>
					</NativeMenu>
				</TrayIcon.Menu>
			</TrayIcon>
		</TrayIcons>
	</TrayIcon.Icons>
</Application>
