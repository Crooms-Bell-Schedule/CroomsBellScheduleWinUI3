<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CBSApp.Controls.SplashScreen"
			 xmlns:ui="using:FluentAvalonia.UI.Controls">
	<Grid x:Name="Loader"
				VerticalAlignment="Stretch"
				HorizontalAlignment="Stretch"
				Background="{DynamicResource SystemAltHighColor}"
				Grid.ColumnSpan="9" Grid.RowSpan="9">

		<Grid.Transitions>
			<Transitions>
				<TransformOperationsTransition Property="RenderTransform" Duration="0:0:2" />
				<DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
			</Transitions>
		</Grid.Transitions>
		<Grid VerticalAlignment="Center" HorizontalAlignment="Center">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="auto"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Grid.RowDefinitions>
				<RowDefinition Height="auto"/>
				<RowDefinition Height="auto"/>
				<RowDefinition Height="auto"/>
			</Grid.RowDefinitions>

			<WrapPanel Grid.Row="0" Grid.Column="1">
				<Svg
					x:Name="BellScheduleLogo"
					Path="/Assets/BellSchedule.svg"
			 Width="64" Height="64" HorizontalAlignment="Center"/>
				<TextBlock x:Name="ProductName" VerticalAlignment="Center" FontSize="40" Margin="10,0,0,0" FontFamily="Segoe UI Light" TextWrapping="Wrap">Crooms Bell Schedule</TextBlock>

			</WrapPanel>


			<ui:FAProgressRing x:Name="loadingRing" Grid.Row="1" Grid.ColumnSpan="9" Height="40" BorderThickness="4" IsIndeterminate="True"/>

			<TextBlock x:Name="LoaderText" Grid.Row="2" Grid.ColumnSpan="9" HorizontalAlignment="Center" Margin="0,10,0,0">Initializing</TextBlock>
		</Grid>
	</Grid>
</UserControl>
